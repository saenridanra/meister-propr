    "/jobs": {
      "get": {
        "tags": [
          "Jobs"
        ],
        "summary": "Returns all review jobs across all clients, newest first. Requires `X-Admin-Key`.",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of items to return (1–1000, default 100).",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 100
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Number of items to skip for pagination (default 0).",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 0
            }
          },
          {
            "name": "status",
            "in": "query",
            "description": "Optional status filter: Pending, Processing, Completed, or Failed.",
